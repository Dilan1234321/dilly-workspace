# YouTube Data API v3 key (used only by the nightly ingest script, never at request time)
YOUTUBE_API_KEY=

# URL of the existing Dilly FastAPI backend (auth, profile, saved videos)
DILLY_API_URL=http://localhost:8000

# Same Postgres URL Dilly core uses — Skill Lab tables live in the same DB
DATABASE_URL=

# Secret shared with FastAPI for verifying session cookies
SESSION_SECRET=

# Public site URL (used for absolute links in OG tags, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://skilllab.dilly.app
