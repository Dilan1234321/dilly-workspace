{
  "expo": {
    "name": "Dilly",
    "slug": "dilly-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "dilly",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "appleTeamId": "F46NQK75DK",
      "bundleIdentifier": "com.dilly.app",
      "buildNumber": "440",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSContactsUsageDescription": "Allow Dilly to look up contacts so you can quickly attach context to interview prep and outreach.",
        "NSCalendarsUsageDescription": "Dilly syncs your application deadlines, interviews, and Chapter sessions to your calendar so they live alongside the rest of your week.",
        "NSRemindersUsageDescription": "Dilly creates Reminders for application deadlines, interview prep, and weekly career check-ins in a dedicated 'Dilly' list.",
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "dilly-warm-cache"
        ],
        "NSCalendarsWriteOnlyAccessUsageDescription": "Allow Dilly to add interview reminders and weekly briefs to your calendar.",
        "NSSupportsLiveActivities": true,
        "NSSupportsLiveActivitiesFrequentUpdates": true
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.dilly.app"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-sharing",
      "expo-mail-composer",
      "expo-background-fetch",
      "expo-task-manager",
      [
        "expo-contacts",
        {
          "contactsPermission": "Dilly saves networking contacts you meet (with a 'Met through Dilly' note) and finds warm intros to companies in your phone before applying."
        }
      ],
      [
        "expo-share-intent",
        {
          "iosShareExtensionName": "Send to Dilly",
          "iosAppGroupIdentifier": "group.com.dilly.app",
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ],
      "@bacons/apple-targets",
      "expo-apple-authentication"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "151a72db-6fa4-4eac-b538-c9317e23a8aa"
      }
    }
  }
}