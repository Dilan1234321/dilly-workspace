# Meridian API — copy to .env and fill in. Never commit .env.
# The API loads this from the workspace root when present.

# Optional: use LLM for audits (personalized evidence + recommendations).
# Leave unset or 0 for rule-based only.
MERIDIAN_USE_LLM=1

# Your OpenAI API key (required if MERIDIAN_USE_LLM=1).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override model or base URL (e.g. Azure).
# MERIDIAN_LLM_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://...
