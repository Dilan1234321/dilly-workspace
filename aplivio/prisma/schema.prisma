generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Anonymous browser session (HttpOnly cookie). Swap for auth-backed User later.
model Session {
  id                     String    @id @default(cuid())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  profile                Json
  savedCollegeIds        Json
  disclaimerAcceptedAt   DateTime?
}
